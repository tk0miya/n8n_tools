      "id": "0b4e7127-a09d-4f2b-918c-407797f305bf",
      "name": "買い物リストにチェック",
      "webhookId": "0e439d56-8a39-4433-ba7b-3462ec1073a6"
    },
    {
      "parameters": {
        "jsCode": "const payload = JSON.parse($json.body.payload);\n\n// チェックされた項目を全ブロックから収集\nconst checked = [];\nfor (const blockState of Object.values(payload.state.values)) {\n  for (const [actionId, actionState] of Object.entries(blockState)) {\n    if (actionId.startsWith('checkbox_action')) {\n      actionState.selected_options.forEach(o => checked.push(o.value));\n    }\n  }\n}\n\n// メッセージ内の全 actions ブロックから選択肢を収集\nconst items = payload.message.blocks\n  .filter(b => b.type === 'actions')\n  .flatMap(b => b.elements[0].options.map(o => o.value));\n\n// 全項目にチェック状態を付与して展開\nreturn items.map(rowNumber => ({\n  json: {\n    rowNumber,\n    checked: checked.includes(rowNumber)\n  }\n}));"
      },
