    {
      "parameters": {
        "jsCode": "const rows = $input\n               .all()\n               .filter(row => Object.keys(row.json).length > 0);\nconst options = rows\n  .filter(row => row.json['disabled'] != true)\n  .map(row => ({\n    text: {\n      type: \"plain_text\",\n      text: row.json['items']\n    },\n    value: String(row.json['row_number'])\n  }));\n\nif (options.length == 0) {\n  return [{\n    json: {\n      payload: JSON.stringify({\n        blocks: [\n          {\n            type: \"section\",\n            text: {\n              type: \"mrkdwn\",\n              text: \"買い物リストは空です\"\n            }\n          }\n        ]\n      })\n    }\n  }];\n}\n\n// 10個ずつに分割してactionsブロックを生成\nconst chunkSize = 10;\nconst actionBlocks = [];\nfor (let i = 0; i < options.length; i += chunkSize) {\n  const chunk = options.slice(i, i + chunkSize);\n  const index = Math.floor(i / chunkSize) + 1;\n  actionBlocks.push({\n    type: \"actions\",\n    elements: [\n      {\n        type: \"checkboxes\",\n        options: chunk,\n        action_id: `checkbox_action_${index}`\n      }\n    ]\n  });\n}\n\nreturn [{\n  json: {\n    payload: JSON.stringify({\n      blocks: [\n        {\n          type: \"section\",\n          text: {\n            type: \"mrkdwn\",\n            text: \"買い物リスト：\"\n          }\n        },\n        ...actionBlocks\n      ]\n    })\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        608,
        -272
      ],
