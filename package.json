{
  "name": "ghscan",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "ghscan": "./dist/ghscan.mjs",
    "ghtoken": "./dist/ghtoken.mjs",
    "ghome": "./dist/ghome.mjs"
  },
  "scripts": {
    "build": "npm run build:ghscan && npm run build:ghtoken && npm run build:ghome",
    "build:ghscan": "esbuild src/ghscan/cli.ts --bundle --platform=node --format=esm --outfile=dist/ghscan.mjs --banner:js='#!/usr/bin/env node\nimport{createRequire}from\"node:module\";const require=createRequire(import.meta.url);' --alias:@=./src",
    "build:ghtoken": "esbuild src/check-token/cli.ts --bundle --platform=node --format=esm --outfile=dist/ghtoken.mjs --banner:js='#!/usr/bin/env node\nimport{createRequire}from\"node:module\";const require=createRequire(import.meta.url);' --alias:@=./src",
    "build:ghome": "esbuild src/google-home/cli.ts --bundle --platform=node --format=esm --outfile=dist/ghome.mjs --external:castv2-player --external:google-tts-api",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "ci": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "castv2-player": "^2.1.3",
    "dotenv": "^17.3.1",
    "google-tts-api": "^2.0.2",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/dedent": "^0.7.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "dedent": "^1.7.2",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
