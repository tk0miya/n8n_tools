{
  "name": "ghscan",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "ghscan": "./dist/ghscan.mjs"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/ghscan.mjs --banner:js='#!/usr/bin/env node'",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "ci": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/js-yaml": "^4.0.9",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
