interface _OctokitContent
  def name: () -> String
  def path: () -> String
  def content: () -> String
end

interface _OctokitUser
  def login: () -> String
end

interface _OctokitRepo
  def name: () -> String
  def updated_at: () -> Time
  def default_branch: () -> String
  def archived: () -> bool
  def fork: () -> bool
  def pushed_at: () -> Time
end

interface _OctokitRelease
  def tag_name: () -> String
end

interface _OctokitTag
  def name: () -> String
end

interface _OctokitWorkflowRun
  def head_sha: () -> String
  def conclusion: () -> String?
end

interface _OctokitWorkflowRuns
  def workflow_runs: () -> Array[_OctokitWorkflowRun]
end

module Octokit
  class Client
    def user: (?(Integer | String) user, ?Hash[untyped, untyped] options) -> _OctokitUser
            | ...

    def repos: (String, ?type: String) -> Array[_OctokitRepo]

    def get: (String, ?branch: String, ?per_page: Integer) -> _OctokitWorkflowRuns

    def pull_requests: (String, ?state: String) -> Array[untyped]

    def contents: (String, ?path: String) -> untyped

    def latest_release: (String) -> _OctokitRelease

    def tags: (String) -> Array[_OctokitTag]
  end
end
